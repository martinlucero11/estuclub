rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isSupplierDocOwner() {
      return signedIn() &&
        exists(/databases/$(database)/documents/roles_supplier/$(request.auth.uid));
    }

    function isAdminDocOwner() {
      return signedIn() &&
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /* ================= USERS ================= */

    match /users/{userId} {
      allow get: if isMe(userId) || isAdminDocOwner();
      allow list: if signedIn();
      allow create: if isMe(userId);
      allow update, delete: if isMe(userId) || isAdminDocOwner();

      match /redeemed_benefits/{id} {
        allow get, list, create, update, delete: if isMe(userId) || isAdminDocOwner();
      }
    }

    match /userTokens/{userId} {
      allow get, list, create, update, delete: if isMe(userId) || isAdminDocOwner();
    }

    /* ================= USERNAMES ================= */

    match /usernames/{username} {
      allow get, list: if true;
      allow create: if signedIn() && (
        request.resource.data.uid == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if false;
    }

    /* ================= ROLES ================= */

    match /roles_admin/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, create, update, delete: if isAdminDocOwner();
    }

    match /roles_supplier/{supplierId} {
      allow get, list: if true;
      allow create, delete: if false;
      allow update: if isMe(supplierId) || isAdminDocOwner()
        || (signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avgRating', 'reviewCount', 'favoritesCount']));

      match /availability/{docId} {
        allow get, list: if true;
        allow create, update, delete: if isMe(supplierId) || isAdminDocOwner();
      }

      match /services/{serviceId} {
        allow get, list: if true;
        allow create, update, delete: if isMe(supplierId) || isAdminDocOwner();
      }

      match /subscribers/{userId} {
        allow get: if isMe(userId) || isMe(supplierId) || isAdminDocOwner();
        allow list: if isMe(supplierId) || isAdminDocOwner();
        allow create: if isMe(userId);
        allow update: if isMe(userId);
        allow delete: if isMe(userId) || isMe(supplierId) || isAdminDocOwner();
      }

      match /appointments/{appointmentId} {
        allow get, list, create, update, delete: if isMe(supplierId) || isAdminDocOwner();
      }
    }

    /* ================= APPOINTMENTS ================= */

    match /appointments/{appointmentId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.supplierId is string;

      allow get: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ) || isAdminDocOwner();

      allow list: if signedIn();

      allow update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ) || isAdminDocOwner();
    }

    /* ================= BENEFIT REDEMPTIONS ================= */

    match /benefitRedemptions/{id} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow get: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ) || isAdminDocOwner();



      allow list: if signedIn();

      allow update: if signedIn() &&
        (resource.data.supplierId == request.auth.uid ||
         resource.data.userId == request.auth.uid ||
         isAdminDocOwner());

      allow delete: if false;
    }

    /* ================= BENEFITS ================= */

    match /benefits/{id} {
      allow get, list: if true;

      allow create: if isSupplierDocOwner() || isAdminDocOwner();

      allow update, delete: if signedIn() && (
        resource.data.supplierId == request.auth.uid ||
        resource.data.ownerId == request.auth.uid
      ) || isAdminDocOwner();
    }

    /* ================= ANNOUNCEMENTS ================= */

    match /announcements/{id} {
      allow get, list: if true;

      allow create: if isSupplierDocOwner() || isAdminDocOwner();

      allow update, delete: if signedIn() && (
        resource.data.supplierId == request.auth.uid ||
        resource.data.ownerId == request.auth.uid ||
        resource.data.authorId == request.auth.uid
      ) || isAdminDocOwner();
    }

    /* ================= PUBLIC CONTENT ================= */

    match /banners/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdminDocOwner();
    }

    match /categories/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdminDocOwner();
    }

    match /home_sections/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdminDocOwner();
    }

    /* ================= NOTIFICATIONS ================= */

    match /notifications/{id} {
      allow get, list: if signedIn() && (resource.data.userId == request.auth.uid || isAdminDocOwner());
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || isAdminDocOwner());
      allow update, delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdminDocOwner());
    }

    /* ================= REVIEWS ================= */

    match /reviews/{id} {
      allow get, list: if true;
      allow create: if signedIn();
      allow update, delete: if isAdminDocOwner();
    }

    /* ================= GLOBAL DENY ================= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
