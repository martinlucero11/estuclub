rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isSupplier() { return isSignedIn() && exists(/databases/$(database)/documents/roles_supplier/$(request.auth.uid)); }

    // --- Public & Semi-Public Data ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /home_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if resource.data.status == 'approved' || (isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.ownerId == request.auth.uid || resource.data.supplierId == request.auth.uid)) || isAdmin();
      allow list: if true;
      allow create: if isSupplier();
      allow update, delete: if (isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.ownerId == request.auth.uid || resource.data.supplierId == request.auth.uid)) || isAdmin();
    }

    match /notifications/{notificationId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSupplier() || isAdmin();
    }

    match /benefits/{benefitId} {
      allow read: if true;
      allow create: if (isSupplier() && request.resource.data.ownerId == request.auth.uid && (request.resource.data.isFeatured == false || !('isFeatured' in request.resource.data))) || isAdmin();
      allow update: if (isSupplier() && (resource.data.ownerId == request.auth.uid || resource.data.supplierId == request.auth.uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isFeatured', 'featuredRank', 'isVisible'])) || isAdmin();
      allow delete: if (isSupplier() && (resource.data.ownerId == request.auth.uid || resource.data.supplierId == request.auth.uid)) || isAdmin();
    }

    // --- User-Specific Data & Roles ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /userTokens/{userId} {
        allow read, write: if isOwner(userId);
    }

    match /users/{userId}/redeemed_benefits/{redemptionId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /benefitRedemptions/{redemptionId} {
      allow read: if (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.supplierId == request.auth.uid)) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSupplier() && resource.data.supplierId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // --- New Appointments Collection ---
    match /appointments/{appointmentId} {
      allow create: if isSignedIn();
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) 
                   || (isSupplier() && resource.data.supplierId == request.auth.uid) 
                   || isAdmin();
      allow update, delete: if (isSignedIn() && resource.data.userId == request.auth.uid) 
                             || (isSupplier() && resource.data.supplierId == request.auth.uid) 
                             || isAdmin();
    }

    // --- Supplier (Cluber) Specific Rules ---
    match /roles_supplier/{supplierId} {
      allow read: if true; // Publicly viewable profile
      allow write: if isAdmin() || 
                    (isOwner(supplierId) && 
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVisible', 'isFeatured', 'featuredRank']));
    
      // --- Nested Rules for Supplier's Features ---
      match /services/{serviceId} {
        allow read: if true;
        allow write: if isOwner(supplierId) || isAdmin();
      }

      match /availability/{schedule} {
        allow read: if true;
        allow write: if isOwner(supplierId) || isAdmin();
      }
      
      match /subscribers/{subscriberId} {
        allow get: if isOwner(subscriberId) || isOwner(supplierId) || isAdmin();
        allow list: if isOwner(supplierId) || isAdmin();
        allow create: if isOwner(subscriberId);
        allow update: if isOwner(subscriberId) || isAdmin();
        allow delete: if isOwner(subscriberId) || isAdmin();
      }

      // Legacy appointments subcollection
      match /appointments/{appointmentId} {
        allow read, write: if isOwner(supplierId) || isAdmin();
      }
    }
    
    // --- Admin-Only Data ---
    match /roles_admin/{adminId} {
        allow get: if isSignedIn() && request.auth.uid == adminId;
        // An admin is someone who has an entry in roles_admin.
        // This avoids the circular dependency of calling isAdmin() on itself.
        allow list: if get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) != null;
        allow write: if get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) != null;
    }
  }
}
