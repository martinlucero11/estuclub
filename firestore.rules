rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function signedIn() {
      return request.auth != null;
    }

    function isMe(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isSupplier() {
      return signedIn() && 
        exists(/databases/$(database)/documents/roles_supplier/$(request.auth.uid));
    }
    
    function isRider() {
      return signedIn() && 
        exists(/databases/$(database)/documents/roles_rider/$(request.auth.uid));
    }

    /* ================= USERS ================= */

    match /users/{userId} {
      allow read: if true;
      allow create: if isMe(userId);
      allow update: if isAdmin() || isMe(userId);
      allow delete: if isAdmin();

      match /redeemed_benefits/{id} {
        allow read, write: if isMe(userId) || isAdmin();
      }
    }

    /* ================= ROLES ================= */

    match /roles_admin/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, write: if isAdmin();
    }

    match /roles_supplier/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if true;
      allow write: if isAdmin();
    }
    
    match /roles_rider/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list, write: if isAdmin();
    }

    /* ================= PUBLIC CONTENT ================= */

    match /perks/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /home_sections/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /* ================= PRODUCTS & ORDERS ================= */

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /orders/{id} {
      allow list: if signedIn();
      allow get, update: if isAdmin() || isRider() || (signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ));
      allow create: if signedIn();
    }

    /* ================= APPLICATIONS ================= */

    match /supplier_requests/{id} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }
    
    match /rider_applications/{id} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    /* ================= LOGISTICS ================= */

    match /benefitRedemptions/{id} {
      allow list: if signedIn();
      allow get, write: if isAdmin() || (signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ));
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    /* ================= GLOBAL ACCESS ================= */

    match /{document=**} {
      allow read, write: if isAdmin();
      allow read: if true;
    }
  }
}
