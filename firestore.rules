rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function signedIn() {
      return request.auth != null;
    }

    function isMe(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isSupplier() {
      return signedIn() && 
        exists(/databases/$(database)/documents/roles_supplier/$(request.auth.uid));
    }
    
    function isRider() {
      return signedIn() && 
        exists(/databases/$(database)/documents/roles_rider/$(request.auth.uid));
    }

    function isIncrementedBy(field, amount) {
      return request.resource.data[field] == resource.data[field] + amount;
    }

    /* ================= USERS ================= */

    match /users/{userId} {
      allow read: if true;
      allow create: if isMe(userId);
      allow update: if isAdmin() || isMe(userId);
      allow delete: if isAdmin();

      match /redeemed_benefits/{id} {
        allow read, write: if isMe(userId) || isAdmin();
      }
    }

    /* ================= ROLES (CRITICAL FIX) ================= */

    match /roles_admin/{uid} {
      // Allow the user to check if they are an admin without triggering isAdmin check
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, write: if isAdmin();
    }

    match /roles_supplier/{uid} {
      // Allow the user to check if they are a supplier without triggering isAdmin check
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if true;
      allow write: if isAdmin();
    }
    
    match /roles_rider/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list, write: if isAdmin();
    }

    /* ================= PERKS & PUBLIC CONTENT ================= */

    match /perks/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /home_sections/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /* ================= PRODUCTS & ORDERS ================= */

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /orders/{id} {
      allow list: if signedIn();
      allow get, update: if isAdmin() || isRider() || (signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ));
      allow create: if signedIn();
    }

    /* ================= ADMIN TOOLS ================= */

    match /benefitRedemptions/{id} {
      allow list: if signedIn();
      allow get, write: if isAdmin() || (signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ));
    }

    match /supplier_requests/{id} {
      allow read, write: if isAdmin() || signedIn();
    }
    
    match /rider_applications/{id} {
      allow read, write: if isAdmin();
      allow create: if signedIn();
      allow get: if signedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    /* ================= REVIEWS ================= */

    match /reviews/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    /* ================= GLOBAL ACCESS ================= */

    match /{document=**} {
      allow read, write: if isAdmin();
      allow read: if true; // Fallback for public collections
    }
  }
}
