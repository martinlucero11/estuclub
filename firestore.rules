rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS (SSoT + Robustez) ================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? getUserDoc().data : null;
    }

    // isAdmin: Detecta rol en perfiles Y opcionalmente en la colección de auditoría roles_admin
    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() && (
        (data != null && data.role == 'admin') || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isSupplier() {
      let data = getUserData();
      return isAuthenticated() && (
        (data != null && (data.role == 'cluber' || data.role == 'supplier')) ||
        exists(/databases/$(database)/documents/roles_supplier/$(request.auth.uid))
      );
    }

    /* 
    function isRider() {
      let data = getUserData();
      return isAuthenticated() && (
        (data != null && data.role == 'rider') ||
        exists(/databases/$(database)/documents/roles_rider/$(request.auth.uid))
      );
    }
    */

    /* ================= USUARIOS & TOKENS ================= */

    match /users/{userId} {
      allow read: if true; // El perfil es público o semi-público para identificación
      allow create: if isAuthenticated() && request.auth.uid == userId; 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /redeemed_benefits/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /userTokens/{userId} {
      // Necesario para que las notificaciones push se registrren correctamente
      allow read, write: if isOwner(userId) || isAdmin();
    }

    /* ================= LOGÍSTICA & TURNOS (ROOT) ================= */

    match /roles_supplier/{supplierId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(supplierId);

      match /availability/{docId} { allow read: if true; allow write: if isOwner(supplierId) || isAdmin(); }
      match /services/{serviceId} { allow read: if true; allow write: if isOwner(supplierId) || isAdmin(); }
      match /appointments/{appointmentId} { allow read, write: if isOwner(supplierId) || isAdmin(); }
      match /subscribers/{userId} { allow read: if true; allow write: if isAuthenticated() && request.auth.uid == userId; }
    }

    /* ================= PEDIDOS (CORE) ================= */

    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid || 
        resource.data.riderId == request.auth.uid || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.supplierId == request.auth.uid || 
        resource.data.riderId == request.auth.uid || 
        isAdmin()
      );
    }

    /* ================= PRODUCTOS, BENEFICIOS & ANUNCIOS ================= */

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || (isSupplier() && request.resource.data.supplierId == request.auth.uid);
    }

    match /benefits/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin() || isSupplier();
    }

    match /benefitRedemptions/{id} {
      allow list: if isAuthenticated();
      allow get, write: if isAdmin() || (isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      ));
    }

    /* ================= SOLICITUDES & FEEDBACK ================= */

    match /supplier_requests/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /rider_applications/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    /* ================= UI & CMS ================= */

    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /home_sections/{id} { allow read: if true; allow write: if isAdmin(); }

    /* ================= GLOBAL ACCESS ================= */

    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
