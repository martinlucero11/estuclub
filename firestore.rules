
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isSupplier() { return isSignedIn() && exists(/databases/$(database)/documents/roles_supplier/$(request.auth.uid)); }

    // --- Public & Semi-Public Data ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /home_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if resource.data.status == 'approved' || (isOwner(resource.data.supplierId) || isAdmin());
      allow list: if true; // Lists are filtered on client for approved status
      allow create: if isSupplier();
      allow update, delete: if isOwner(resource.data.supplierId) || isAdmin();
    }

    match /notifications/{notificationId} {
      allow list, get: if true;
      allow write: if isSupplier() || isAdmin();
    }

    match /benefits/{benefitId} {
      allow read: if true;
      // Admin can do anything.
      // Supplier can create if they own it and are NOT setting it as featured.
      allow create: if (isSupplier() && request.resource.data.ownerId == request.auth.uid && (request.resource.data.isFeatured == false || !('isFeatured' in request.resource.data))) || isAdmin();
      // Admin can do anything.
      // Supplier can update if they own it and are NOT changing sensitive admin-only fields.
      allow update: if (isSupplier() && resource.data.ownerId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isFeatured', 'featuredRank', 'isVisible'])) || isAdmin();
      allow delete: if (isSupplier() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    // --- User-Specific Data & Roles ---
    match /users/{userId} {
      // Allow signed-in users to read profiles, but only owner/admin can write.
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /userTokens/{userId} {
        allow read, write: if isOwner(userId);
    }

    match /users/{userId}/redeemed_benefits/{redemptionId} {
      // A user can manage their own redemption history
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /benefitRedemptions/{redemptionId} {
      allow read: if (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.supplierId == request.auth.uid)) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSupplier() && resource.data.supplierId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // --- New Appointments Collection ---
    match /appointments/{appointmentId} {
      allow create: if isSignedIn();
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) 
                   || (isSupplier() && resource.data.supplierId == request.auth.uid) 
                   || isAdmin();
      allow update, delete: if (isSignedIn() && resource.data.userId == request.auth.uid) 
                             || (isSupplier() && resource.data.supplierId == request.auth.uid) 
                             || isAdmin();
    }

    // --- Supplier (Cluber) Specific Rules ---
    match /roles_supplier/{supplierId} {
      allow read: if true; // Publicly viewable profile
      // Admin can write anything.
      // Owner can write, but cannot change sensitive, admin-only fields.
      allow write: if isAdmin() || 
                    (isOwner(supplierId) && 
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVisible', 'isFeatured', 'featuredRank']));
    
      // --- Nested Rules for Supplier's Features ---
      match /services/{serviceId} {
        allow read: if true;
        allow write: if isOwner(supplierId) || isAdmin();
      }

      match /availability/{schedule} {
        allow read: if true;
        allow write: if isOwner(supplierId) || isAdmin();
      }
      
      // Rule for subscribers subcollection.
      match /subscribers/{subscriberId} {
        // A user can read their own subscription document. A supplier or admin can also read it.
        allow get: if isOwner(subscriberId) || isOwner(supplierId) || isAdmin();
        // Only the supplier or an admin can list all subscribers.
        allow list: if isOwner(supplierId) || isAdmin();
        // A user can create their own subscription document.
        allow create: if isOwner(subscriberId);
        // A user can update their own subscription document.
        allow update: if isOwner(subscriberId) || isAdmin();
        // A user can delete their own subscription document (unsubscribe).
        allow delete: if isOwner(subscriberId) || isAdmin();
      }
    }
    
    // --- Admin-Only Data ---
    match /roles_admin/{adminId} {
      allow read: if isSignedIn(); // Allow any signed-in user to check admin status
      allow write: if isAdmin(); // Only other admins can make someone an admin
    }
  }
}
