rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/roles_admin/$(request.auth.uid));
    }

    /* ================= PUBLIC CONTENT ================= */
    
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ================= USER ASSETS ================= */

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    /* ================= APPLICATIONS (NEW) ================= */

    match /rider_applications/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /supplier_requests/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    /* ================= SUPPLIER ASSETS ================= */

    match /suppliers/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    /* ================= PRODUCTS ================= */

    match /products/{supplierId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(supplierId);
    }

    /* ================= FALLBACK ================= */

    match /{path=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
